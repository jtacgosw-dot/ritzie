{
  "id": "high-contrast",
  "name": "High Contrast Gov/AA",
  "brand": {
    "logoUrl": "",
    "avatarUrl": "",
    "accent": "#0F172A"
  },
  "colors": {
    "light": {
      "bg": "#FFFFFF",
      "panel": "#FFFFFF",
      "text": "#000000",
      "muted": "#374151",
      "divider": "#000000",
      "chip": "#F8F9FA",
      "input": "#FFFFFF"
    },
    "dark": {
      "bg": "#000000",
      "panel": "#000000",
      "text": "#FFFFFF",
      "muted": "#D1D5DB",
      "divider": "#FFFFFF",
      "chip": "#1F2937",
      "input": "#000000"
    }
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
    "baseSize": 16,
    "lineHeight": 1.6
  },
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 8,
    "pill": 999
  },
  "space": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24
  },
  "shadow": {
    "elevation": "0 2px 8px rgba(0,0,0,.5)"
  },
  "layout": {
    "mode": "bubble",
    "bubbleWidth": 480,
    "bubbleMaxHeightVh": 90,
    "pageHeader": true,
    "mountSelector": "#ritzie-chat"
  },
  "motion": {
    "curvePrimary": "ease-in-out",
    "durations": {
      "micro": 100,
      "content": 150,
      "macro": 200,
      "stagger": 30
    },
    "reducedMotion": true
  },
  "components": {
    "message": {
      "userBg": "accent",
      "botBg": "chip"
    },
    "chip": {
      "bordered": true
    },
    "button": {
      "style": "solid"
    }
  },
  "personality": {
    "tone": "calm_pro",
    "emoji": false
  }
}
